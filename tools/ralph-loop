#!/usr/bin/env bash
# Ralph Wiggum Loop - Convenience Command Wrapper
# Wraps ralph_loop_runner.py for easy invocation

# Get script directory
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECT_DIR="$( cd "$SCRIPT_DIR/.." && pwd )"

# Check if running from correct directory
if [ ! -f "$SCRIPT_DIR/ralph_loop_runner.py" ]; then
    echo "❌ Error: ralph_loop_runner.py not found"
    echo "Make sure you're in the project root directory"
    exit 1
fi

# Run the Python script with all arguments
cd "$PROJECT_DIR"
python3 "$SCRIPT_DIR/ralph_loop_runner.py" "$@"
